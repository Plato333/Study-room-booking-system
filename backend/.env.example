# ==========================================
# 环境变量模板文件
# 使用方法：复制本文件为 .env，然后填入真实配置值
#   cp .env.example .env
# 注意：.env 包含敏感信息（如 API Key），已通过 .gitignore 排除，不要提交到 Git
# ==========================================

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=请填写数据库密码
DB_DATABASE=rainier_training

# JWT 配置
JWT_SECRET=rainier_jwt_secret_2026
JWT_EXPIRES_IN=7d

# 服务端口
PORT=3000

# 大模型 API 配置
# 模型供应商：qwen（通义千问）或 wenxin（文心一言）
AI_PROVIDER=qwen
# API 地址（OpenAI 兼容格式）
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 模型名称
AI_MODEL=qwen-plus
# API Key（请填写自己的大模型 API KEY）
AI_API_KEY=请填写自己的大模型API_KEY
